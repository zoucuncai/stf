.stf-dashboard

  //- 顶部标题
  .dashboard-header
    i.fa.fa-tachometer
    span  设备看板
    span.dashboard-refresh-tip  (每3秒自动刷新)

  //- 汇总统计卡片
  .dashboard-summary
    .summary-card.summary-total(
      ng-click='setFilter("all")'
      ng-class='{active: stateFilter === "all"}')
        .summary-number {{tracker.devices.length}}
        .summary-label 全部设备

    .summary-card.summary-available(
      ng-click='setFilter("available")'
      ng-class='{active: stateFilter === "available"}')
        .summary-number {{stats.available}}
        .summary-label 可用

    .summary-card.summary-using(
      ng-click='setFilter("using")'
      ng-class='{active: stateFilter === "using"}')
        .summary-number {{stats.using}}
        .summary-label 使用中

    .summary-card.summary-busy(
      ng-click='setFilter("busy")'
      ng-class='{active: stateFilter === "busy"}')
        .summary-number {{stats.busy}}
        .summary-label 已预约

    .summary-card.summary-automation(
      ng-click='setFilter("automation")'
      ng-class='{active: stateFilter === "automation"}')
        .summary-number {{stats.automation}}
        .summary-label 自动化

    .summary-card.summary-offline(
      ng-click='setFilter("offline")'
      ng-class='{active: stateFilter === "offline"}')
        .summary-number {{stats.offline}}
        .summary-label 离线

  //- 无设备提示
  .dashboard-empty(ng-if='tracker.devices.length === 0')
    i.fa.fa-mobile.fa-3x
    p 暂无设备

  //- 设备卡片网格
  .dashboard-devices

    .device-card(
      ng-repeat='device in tracker.devices track by device.serial'
      ng-if='isVisible(device)'
      ng-class='getCardClass(device)')

      //- 卡片头部：图标 + 名称 + 状态
      .device-card-header
        img.device-thumb(ng-src='{{device.enhancedImage24}}')
        .device-info
          .device-name(title='{{device.enhancedName}}') {{device.enhancedName}}
          .device-model {{device.model || device.serial}}
        span.device-state-label {{getStateName(device)}}

      //- 卡片主体：各项指标
      .device-card-body

        //- 电量
        .metric-row
          .metric-label
            i.fa.fa-battery-three-quarters
            |  电量
          .metric-right(ng-if='device.battery')
            .progress.battery-bar
              .progress-bar(
                ng-class='getBatteryBarClass(device)'
                ng-style='{width: getBatteryPercent(device) + "%"}'
                ng-bind='getBatteryPercent(device) + "%"')
            i.fa.fa-bolt.charging-icon(
              ng-if='isCharging(device)'
              title='充电中')
          .metric-right(ng-if='!device.battery')
            span.text-muted --

        //- 温度
        .metric-row
          .metric-label
            i.fa.fa-thermometer-half
            |  温度
          .metric-right
            span(
              ng-if='device.battery'
              ng-class='getTempClass(device)') {{device.battery.temp}}°C
            span.text-muted(ng-if='!device.battery') --

        //- CPU 使用率
        .metric-row
          .metric-label
            i.fa.fa-microchip
            |  CPU
          .metric-right(ng-if='device.performance')
            .progress.battery-bar
              .progress-bar(
                ng-class='getCpuBarClass(device)'
                ng-style='{width: device.performance.cpu + "%"}'
                ng-bind='device.performance.cpu + "%"')
          .metric-right(ng-if='!device.performance')
            span.text-muted --

        //- 内存使用率
        .metric-row
          .metric-label
            i.fa.fa-server
            |  内存
          .metric-right(ng-if='device.performance')
            .progress.battery-bar
              .progress-bar(
                ng-class='getMemBarClass(device)'
                ng-style='{width: device.performance.mem + "%"}'
                ng-bind='device.performance.mem + "%"')
            span.mem-label {{getMemLabel(device)}}
          .metric-right(ng-if='!device.performance')
            span.text-muted --

        //- 使用人
        .metric-row(ng-if='device.owner')
          .metric-label
            i.fa.fa-user
            |  使用人
          .metric-right
            span {{device.owner.name || device.owner.email}}

        //- 网络
        .metric-row(ng-if='getNetworkStr(device)')
          .metric-label
            i.fa.fa-wifi
            |  网络
          .metric-right
            span {{getNetworkStr(device)}}

        //- 预约群组
        .metric-row(ng-if='device.group && device.group.name && device.group.class !== "standard"')
          .metric-label
            i.fa.fa-object-group
            |  预约
          .metric-right
            span(title='{{device.group.name}}') {{device.group.name}}

